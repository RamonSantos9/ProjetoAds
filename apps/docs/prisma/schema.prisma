generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String            @id @default(cuid())
  name                   String?
  email                  String?           @unique
  password               String?
  emailVerified          DateTime?
  image                  String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  role                   UserRole          @default(USUARIO)
  academicRole           String?
  acceptedTerms          Boolean           @default(false)
  hasIndividualWorkspace Boolean           @default(false)
  joinedGlobalWorkspace  Boolean           @default(false)
  onboardingCompletedAt  DateTime?
  sourceChannel          String?
  wantsUpdates           Boolean           @default(false)
  dataUsageConsent       Boolean           @default(false)
  personalWorkspaceName  String?
  accounts               Account[]
  episodes               Episode[]
  feedbacks              Feedback[]
  guests                 Guest[]
  sessions               Session[]
  projects               StudioProject[]
  visualAssets           VisualAsset[]
  invitesSent            WorkspaceInvite[] @relation("InvitesSent")
  workspaceMemberships   WorkspaceMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Episode {
  id                String         @id @default(cuid())
  slug              String         @unique
  title             String
  summary           String
  category          String
  status            String
  duration          String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  audioUrl          String?
  externalUrl       String?
  transcriptionText String?
  language          String?
  confidence        Float?
  image             String?
  platforms         Json?
  segments          Json?
  tracks            Json?
  sharingConfig     Json?
  assets            Json?
  ownerId           String?
  scheduledAt       DateTime?
  workspaceId       String         @default("global")
  owner             User?          @relation(fields: [ownerId], references: [id])
  guests            EpisodeGuest[]
  playEvents        PlayEvent[]
  visualAssets      VisualAsset[]
}

model Guest {
  id          String         @id @default(cuid())
  name        String
  bio         String?
  social      String?
  avatar      String?
  email       String?
  ownerId     String?
  createdAt   DateTime       @default(now())
  workspaceId String         @default("global")
  company     String?
  linkedin    String?
  phone       String?
  website     String?
  episodes    EpisodeGuest[]
  owner       User?          @relation(fields: [ownerId], references: [id])
}

model EpisodeGuest {
  episodeId String
  guestId   String
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  guest     Guest   @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@id([episodeId, guestId])
}

model StudioProject {
  id           String   @id @default(cuid())
  name         String
  aspectRatio  String   @default("16 / 9")
  lastModified DateTime @default(now())
  createdAt    DateTime @default(now())
  tracks       Json?
  assets       Json?
  ownerId      String?
  workspaceId  String   @default("global")
  owner        User?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Feedback {
  id          String   @id @default(cuid())
  avatar      String
  user        String
  role        String
  message     String
  ownerId     String?
  createdAt   DateTime @default(now())
  workspaceId String   @default("global")
  owner       User?    @relation(fields: [ownerId], references: [id])
}

model VisualAsset {
  id          String   @id @default(cuid())
  episodeId   String?
  title       String
  type        String
  url         String
  createdAt   DateTime @default(now())
  ownerId     String?
  workspaceId String   @default("global")
  episode     Episode? @relation(fields: [episodeId], references: [id])
  owner       User?    @relation(fields: [ownerId], references: [id])
}

model PlayEvent {
  id          String   @id @default(cuid())
  episodeId   String
  device      String
  createdAt   DateTime @default(now())
  workspaceId String   @default("global")
  episode     Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
}

model GlobalWorkspace {
  id      String            @id @default("global")
  name    String            @default("Portal Administrativo")
  type    String            @default("Acesso Geral")
  plan    String            @default("Plano Institucional")
  members WorkspaceMember[]
}

model WorkspaceMember {
  id              String          @id @default(cuid())
  userId          String
  workspaceId     String
  role            WorkspaceRole   @default(VIEWER)
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  globalWorkspace GlobalWorkspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

model WorkspaceInvite {
  id          String   @id @default(cuid())
  email       String
  role        UserRole @default(USUARIO)
  inviterId   String
  workspaceId String   @default("global")
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  inviter     User     @relation("InvitesSent", fields: [inviterId], references: [id], onDelete: Cascade)
}

enum UserRole {
  USUARIO
  ALUNO
  PROFESSOR
  ADMIN
}

enum WorkspaceRole {
  ADMIN
  EDITOR
  VIEWER
}
