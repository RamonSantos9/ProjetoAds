{
  "name": "@xispedocs/tailwind",
  "version": "1.2.0",
  "description": "The Tailwind CSS utils for XispeDocs UI.",
  "keywords": [
    "Docs",
    "XispeDocs"
  ],
  "homepage": "https://ramonxp.dev",
  "license": "MIT",
  "author": "XispeDocs",
  "repository": "https://github.com/RamonSantos9/XispeDocs.git",
  "files": [
    "dist/*"
  ],
  "type": "module",
  "exports": {
    "./compile": {
      "types": "./dist/compile.d.ts",
      "import": "./dist/compile.js"
    },
    "./typography": {
      "types": "./dist/typography/index.d.ts",
      "import": "./dist/typography/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "postcss-selector-parser": "^7.1.1"
  },
  "devDependencies": {
    "@tailwindcss/oxide": "^4.2.1",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^25.4.0",
    "eslint-config-custom": "workspace:*",
    "lodash.merge": "^4.6.2",
    "tailwindcss": "^4.2.1",
    "tsconfig": "workspace:*",
    "tsup": "8.5.0"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  }
}
